# Exclude files that are not needed in the Docker build context.
# This keeps the context small and avoids accidentally copying sensitive data.

.git
.gitignore
.env
.env.*

# Editor and OS artifacts
.idea/
.vscode/
.DS_Store
Thumbs.db

# Documentation (not needed at build time)
*.md

# Keep config in build context because Dockerfile copies config/opencode.json
