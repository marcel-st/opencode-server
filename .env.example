# ──────────────────────────────────────────────────────────────────────────────
# opencode-server  ·  .env.example
#
# Copy this file to .env and set your own values before starting the stack:
#   cp .env.example .env
#
# The .env file is gitignored and will never be committed to version control.
# It is read by docker compose on your laptop; the resolved values are passed
# as environment variables to the containers on the remote host.
# ──────────────────────────────────────────────────────────────────────────────

# ── Authentication ─────────────────────────────────────────────────────────────
# Username and password used to protect the opencode server with HTTP basic-auth.
# If OPENCODE_SERVER_PASSWORD is left empty the server starts WITHOUT
# authentication (a warning will be printed to the logs).
#
# IMPORTANT: always quote values that contain special characters (!, $, #, =, @, …).
# Use single quotes to prevent the shell / Docker Compose from expanding variables
# inside the value.  Example: OPENCODE_SERVER_PASSWORD='p@$$w0rd#42!'
OPENCODE_SERVER_USERNAME=opencode
OPENCODE_SERVER_PASSWORD='changeme'

# ── opencode runtime version ──────────────────────────────────────────────────
# Defaults to latest when not set. Pin this if you need a specific release.
# If provider or proxy behavior looks different from current docs, set this to
# latest and rebuild the opencode image.
OPENCODE_VERSION=latest

# ── Performance tuning ─────────────────────────────────────────────────────────
# Number of inference requests ollama processes in parallel.
# Each extra slot consumes additional VRAM; lower this value on GPUs with
# less than 12 GB of VRAM, or raise it if you have headroom.
OLLAMA_NUM_PARALLEL=4

# ── Open WebUI API key ────────────────────────────────────────────────────────
# API key for Open WebUI's OpenAI-compatible endpoint.
# Generate one in Open WebUI → Settings → Account → API Keys.
# opencode routes all LLM calls through Open WebUI so it can use the built-in
# SearXNG RAG pipeline instead of calling Ollama directly. This must be a real
# key; leaving the placeholder in place will break Open WebUI-backed responses.
OPENWEBUI_API_KEY=sk-your-open-webui-api-key-here

# ── Web search (Open WebUI + SearXNG) ─────────────────────────────────────────
# Open WebUI web-search is enabled by default and uses the internal searxng
# service. Tune how many results are fetched and how many parallel HTTP calls
# are made per query.
#
# Open WebUI handles web RAG for opencode sessions. Native model-level
# websearch stays disabled because local models often print JSON-shaped tool
# calls instead of returning structured OpenAI tool_calls.
OPENCODE_ENABLE_EXA=false
# SearXNG base URL used by the opencode proxy's direct search injection and by
# the optional custom websearch/webfetch overrides.
OPENCODE_SEARXNG_URL=http://searxng:8080
RAG_WEB_SEARCH_RESULT_COUNT=5
RAG_WEB_SEARCH_CONCURRENT_REQUESTS=10
