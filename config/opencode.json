{
  "$schema": "https://opencode.ai/config.json",

  "server": {
    "hostname": "0.0.0.0",
    "port": 4096
  },

  "provider": {
    "open-webui": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Open WebUI",
      "options": {
        "baseURL": "http://open-webui:8080/api",
        "apiKey": "${OPENWEBUI_API_KEY}"
      },
      "models": {
        "llama3.1:8b": {
          "name": "Llama 3.1 8B"
        },
        "mistral:7b": {
          "name": "Mistral 7B"
        },
        "ministral-3:8b": {
          "name": "Ministral 3 8B"
        },
        "codellama:7b": {
          "name": "Code Llama 7B"
        },
        "qwen2.5-coder:7b": {
          "name": "Qwen 2.5 Coder 7B"
        },
        "gemma4:e4b": {
          "name": "Gemma 4 8B"
        }
      }
    }
  },

  "enabled_providers": [
    "open-webui"
  ],

  "permission": {
    "skill": "deny"
  },

  "model": "open-webui/llama3.1:8b"
}
